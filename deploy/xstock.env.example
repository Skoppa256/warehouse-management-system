# ============================================================================
# xStock deployment configuration
# ----------------------------------------------------------------------------
# Copy this file to `xstock.env` (same folder) and fill in the values, then run
# the scripts in this folder in order. Every deploy script sources this file.
#
#   cp xstock.env.example xstock.env
#   nano xstock.env
#
# `xstock.env` holds secrets — it is gitignored. Never commit it.
# ============================================================================

# --- Public hostname --------------------------------------------------------
# The domain/subdomain you have pointed at this server (A record -> 43.129.49.231).
# The app is served at https://$WMS_DOMAIN  (API is proxied under /api).
WMS_DOMAIN="xstock.primamakmurbersama.com"

# Email used by Let's Encrypt / Certbot for the TLS certificate + expiry notices.
LETSENCRYPT_EMAIL="you@example.com"

# --- Where the code lives on this server ------------------------------------
# Absolute path to the cloned repo root (the folder that contains backend/ and
# frontend/). Leave blank to auto-detect from this deploy/ folder's location.
APP_DIR=""

# Linux user that owns the app and runs the PM2 processes.
APP_USER="ubuntu"

# --- Ports (must be free on this VPS — scripts verify this) -----------------
# These are bound to 127.0.0.1 only; the public never reaches them directly,
# only Nginx (80/443) does. Pick anything free if these clash with the
# existing payslip app. `ss -tlnp` is printed during provisioning.
FRONTEND_PORT="3100"
BACKEND_PORT="3101"

# Interface the frontend binds to. Default 127.0.0.1 (loopback). Set to 0.0.0.0
# if a reverse proxy running in Docker (e.g. an existing Caddy/Nginx container)
# must reach it through the host gateway. ufw still controls public access.
FRONTEND_HOST="127.0.0.1"
# Same idea for the backend (NestJS honours the HOST env). Set 0.0.0.0 when
# fronted by a Dockerised reverse proxy that reaches it via the host gateway.
BACKEND_HOST="127.0.0.1"

# --- Existing Dockerised reverse proxy (Caddy) integration ------------------
# Used by deploy/caddy-add-xstock.sh when an existing Caddy *container* (not
# host Nginx) already owns 80/443. HOST_GATEWAY is the docker bridge gateway the
# proxy uses to reach host services (docker inspect <caddy> ... .Gateway).
CADDY_CONTAINER="payslip-caddy-prod"
CADDYFILE_PATH="/home/ubuntu/payslip/Caddyfile"
HOST_GATEWAY="172.18.0.1"

# --- PostgreSQL (dedicated DB + role created just for xStock) ---------------
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="xstock"
DB_USER="xstock"
# Leave blank to have provision.sh generate a strong password and write it back
# into xstock.env automatically.
DB_PASSWORD=""

# --- Redis (shared server, but a dedicated logical DB index) ----------------
# Using a non-zero DB index keeps xStock's keys separate from the payslip app's
# (which most likely uses index 0). Change if 3 is already taken.
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_DB="3"

# --- App secrets ------------------------------------------------------------
# Leave blank to have provision.sh generate a strong value and write it back.
# The backend refuses to start if JWT_SECRET is empty.
JWT_SECRET=""

# Optional: Resend API key for the registration email-verification flow.
# Leave blank to disable email verification (seeded/admin login still works).
RESEND_API_KEY=""

# --- Seeding ----------------------------------------------------------------
# Set to "true" to run the (idempotent) seed on setup: creates admin@xstock.test
# etc. + sample master data. Safe to re-run. Set "false" to skip.
RUN_SEED="true"
# Password for all seeded accounts.
SEED_ADMIN_PASSWORD="password123"

# --- PM2 process names ------------------------------------------------------
PM2_BACKEND_NAME="xstock-backend"
PM2_FRONTEND_NAME="xstock-frontend"
